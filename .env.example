# Lunch agent environment (copy to .env and fill in on Ghost)

# Confirmation: simulate (default) or discord
LUNCH_AGENT_CONFIRMATION=discord

# Discord: fake (offline tests) or live (real REST calls)
LUNCH_AGENT_DISCORD_MODE=live
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Provider: mock (default), uber, yelp, or osm
LUNCH_AGENT_UBER_MODE=fake
LUNCH_AGENT_YELP_MODE=fake
LUNCH_AGENT_OSM_MODE=fake
YELP_API_KEY=
YELP_LATITUDE=40.7580
YELP_LONGITUDE=-73.9855
YELP_SEARCH_TERM=lunch
OSM_LATITUDE=40.7580
OSM_LONGITUDE=-73.9855
OSM_RADIUS_METERS=1500
LUNCH_AGENT_GOOGLE_PLACES_MODE=off
GOOGLE_PLACES_API_KEY=
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_API_BASE=https://sandbox-api.uber.com

# Optional LLM allergen matching
# LUNCH_AGENT_USE_LLM=true
# OPENAI_API_KEY=
